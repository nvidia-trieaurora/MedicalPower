# MedicalPower Docker Compose Environment Variables
# Copy this file to .env and customize values

# PostgreSQL
POSTGRES_PASSWORD=mp_secret_dev

# Redis
REDIS_PASSWORD=mp_redis_dev

# RabbitMQ
RABBITMQ_PASSWORD=mp_rabbit_dev

# MinIO
MINIO_ACCESS_KEY=mp_minio_dev
MINIO_SECRET_KEY=mp_minio_secret_dev

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=admin_dev

# MONAI Label (only used with --profile gpu)
# Requires NVIDIA GPU + Docker GPU runtime
