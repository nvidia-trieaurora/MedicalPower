{
  "Name": "MedicalPower DICOM Server",
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,

  "DicomPort": 4242,
  "HttpPort": 8042,

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "WadoRoot": "/wado",
    "Host": "0.0.0.0",
    "Ssl": false,
    "StowMaxInstances": 10,
    "StowMaxSize": 10
  },

  "OrthancExplorer2": {
    "Enable": true,
    "IsDefaultOrthancUI": true,
    "UiOptions": {
      "EnableUpload": true,
      "EnableDeleteResources": true,
      "EnableApiViewMenu": false,
      "EnableSettings": false,
      "EnableLinkToSourceCode": false,
      "MaxStudiesDisplayed": 100,
      "ShowOrthancName": true,
      "StudyListSearchMode": "search-as-you-type",
      "StudyListContentIfNoSearch": "most-recents",
      "EnableOpenInOhifViewer3": true,
      "OhifViewer3PublicRoot": "http://localhost:3001/",
      "EnableShares": false
    },
    "Tokens": {},
    "Theme": "dark"
  },

  "StableAge": 5,
  "StorageCompression": false,
  "MaximumStorageSize": 0,
  "MaximumPatientCount": 0,
  "LimitFindResults": 100,
  "LimitFindInstances": 100,

  "HttpsCACertificates": "",
  "ConcurrentJobs": 2,
  "HttpThreadsCount": 50,

  "Cors": {
    "AllowHeaders": "Content-Type, Authorization, Accept, Range",
    "AllowMethods": "GET, POST, PUT, DELETE, OPTIONS",
    "AllowOrigin": ["http://localhost:3000", "http://localhost:3001"],
    "AllowCredentials": true
  },

  "DicomModalities": {},
  "OrthancPeers": {}
}
